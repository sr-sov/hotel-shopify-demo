<style>
.amenities {
  padding: 100px 40px;
  background: var(--white);
  border-top: 1px solid var(--border-light);
  border-bottom: 1px solid var(--border-light);
}

.amenities-inner {
  max-width: var(--max-width);
  margin: 0 auto;
}

.amenities-header {
  text-align: center;
  margin-bottom: 64px;
}

.amenities-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 24px;
}

.amenity-card {
  text-align: center;
  padding: 32px 20px;
  border: 1px solid var(--border-light);
  border-radius: var(--radius);
  transition: all var(--transition);
  background: var(--bg);
}

.amenity-card:hover {
  border-color: var(--accent);
  transform: translateY(-4px);
  box-shadow: var(--shadow);
}

.amenity-icon {
  font-size: 32px;
  margin-bottom: 16px;
  color: var(--accent);
}

.amenity-name {
  font-family: var(--font-display);
  font-size: 18px;
  font-weight: 600;
  margin-bottom: 8px;
  color: var(--text);
}

.amenity-desc {
  font-size: 13px;
  color: var(--text-secondary);
  line-height: 1.6;
}

@media (max-width: 900px) {
  .amenities-grid {
    grid-template-columns: repeat(2, 1fr);
  }
}

@media (max-width: 500px) {
  .amenities-grid {
    grid-template-columns: 1fr;
  }
}
</style>

<section class="amenities" id="amenities">
  <div class="amenities-inner">
    <div class="amenities-header">
      {% if section.settings.tag != blank %}
        <div class="section-tag">{{ section.settings.tag }}</div>
      {% endif %}
      
      {% if section.settings.title != blank %}
        <h2 class="section-title">{{ section.settings.title }}</h2>
      {% endif %}
    </div>

    <div class="amenities-grid">
      {% for block in section.blocks %}
        <div class="amenity-card">
          <div class="amenity-icon">{{ block.settings.icon }}</div>
          <h3 class="amenity-name">{{ block.settings.title }}</h3>
          <p class="amenity-desc">{{ block.settings.desc }}</p>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Amenities Grid",
  "settings": [
    {
      "type": "text",
      "id": "tag",
      "label": "Tag",
      "default": "Amenities & Wellness"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Everything You Need, Nothing You Don't"
    }
  ],
  "blocks": [
    {
      "type": "amenity",
      "name": "Amenity",
      "limit": 8,
      "settings": [
        {
          "type": "text",
          "id": "icon",
          "label": "Emoji Icon",
          "default": "🧖"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Spa & Wellness"
        },
        {
          "type": "textarea",
          "id": "desc",
          "label": "Description",
          "default": "Full-service spa with traditional and modern treatments in a rainforest setting"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Amenities Grid",
      "blocks": [
        { "type": "amenity", "settings": { "icon": "🧖", "title": "Spa & Wellness", "desc": "Full-service spa with traditional and modern treatments in a rainforest setting" } },
        { "type": "amenity", "settings": { "icon": "🏊", "title": "Infinity Pool", "desc": "Heated infinity pool overlooking the valley with poolside dining service" } },
        { "type": "amenity", "settings": { "icon": "🍽️", "title": "Fine Dining", "desc": "Farm-to-table restaurant featuring seasonal menus from local ingredients" } },
        { "type": "amenity", "settings": { "icon": "🌄", "title": "Guided Tours", "desc": "Curated nature walks, waterfall hikes, and cultural experiences with local guides" } }
      ]
    }
  ]
}
{% endschema %}
