<style>
.cart-page {
  padding: 160px 48px 100px;
  background: var(--bg);
  min-height: 80vh;
}

.cart-inner {
  max-width: var(--max-width);
  margin: 0 auto;
}

.cart-header {
  text-align: center;
  margin-bottom: 60px;
}

.cart-title {
  font-family: var(--font-display);
  font-size: clamp(32px, 5vw, 48px);
  font-weight: 500;
  margin-bottom: 12px;
}

.cart-empty {
  text-align: center;
  padding: 80px 0;
}

.cart-empty p {
  font-size: 16px;
  color: var(--text-secondary);
  margin-bottom: 32px;
}

.cart-table-wrapper {
  background: var(--white);
  border-radius: var(--radius);
  border: 1px solid var(--border-light);
  overflow: hidden;
  box-shadow: var(--shadow);
  margin-bottom: 40px;
}

.cart-item {
  display: grid;
  grid-template-columns: 120px 2fr 1fr 1fr;
  gap: 24px;
  padding: 24px;
  border-bottom: 1px solid var(--border-light);
  align-items: center;
}

.cart-item:last-child {
  border-bottom: none;
}

.cart-item-image {
  aspect-ratio: 1;
  border-radius: var(--radius-sm);
  overflow: hidden;
}

.cart-item-image img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.cart-item-details h3 {
  font-family: var(--font-display);
  font-size: 18px;
  margin-bottom: 8px;
}

.cart-item-properties {
  font-size: 13px;
  color: var(--text-secondary);
}

.cart-item-properties p {
  margin-bottom: 4px;
}

.cart-item-price {
  font-weight: 600;
  color: var(--text);
}

.cart-item-remove {
  text-align: right;
}

.cart-item-remove a {
  font-size: 12px;
  color: var(--text-muted);
  text-decoration: underline;
  transition: color var(--transition);
}

.cart-item-remove a:hover {
  color: #c0392b;
}

.cart-summary {
  display: grid;
  grid-template-columns: 1fr 400px;
  gap: 48px;
  align-items: start;
}

.cart-notes {
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.cart-notes label {
  font-size: 13px;
  font-weight: 600;
  color: var(--text-secondary);
}

.cart-notes textarea {
  padding: 16px;
  border: 1px solid var(--border);
  border-radius: var(--radius-sm);
  background: var(--bg-alt);
  min-height: 120px;
  font-family: var(--font-body);
  transition: border-color var(--transition);
}

.cart-notes textarea:focus {
  outline: none;
  border-color: var(--accent);
}

.cart-checkout-box {
  background: var(--white);
  padding: 32px;
  border-radius: var(--radius);
  border: 1px solid var(--border-light);
  box-shadow: var(--shadow);
}

.checkout-row {
  display: flex;
  justify-content: space-between;
  margin-bottom: 16px;
  font-size: 15px;
}

.checkout-total {
  font-size: 20px;
  font-weight: 700;
  border-top: 1px solid var(--border-light);
  padding-top: 16px;
  margin-top: 16px;
}

.btn-checkout {
  width: 100%;
  padding: 18px;
  background: var(--accent);
  color: white;
  border: none;
  border-radius: var(--radius-sm);
  font-family: var(--font-body);
  font-size: 13px;
  font-weight: 600;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  cursor: pointer;
  margin-top: 24px;
  transition: all var(--transition);
}

.btn-checkout:hover {
  background: var(--accent-hover);
  transform: translateY(-2px);
  box-shadow: var(--shadow-lg);
}

@media (max-width: 900px) {
  .cart-item {
    grid-template-columns: 80px 1fr;
    gap: 16px;
  }
  .cart-item-price, .cart-item-remove {
    grid-column: 2;
    text-align: left;
  }
  .cart-summary {
    grid-template-columns: 1fr;
  }
}
</style>

<div class="cart-page">
  <div class="cart-inner">
    <div class="cart-header">
      <h1 class="cart-title">Your Cart</h1>
      <p class="section-tag">Confirm your luxurious stay</p>
    </div>

    {% if cart.item_count > 0 %}
      <form action="/cart" method="post" novalidate>
        <div class="cart-table-wrapper">
          {% for item in cart.items %}
            <div class="cart-item">
              <div class="cart-item-image">
                <a href="{{ item.url }}">
                  <img src="{{ item.image | image_url: width: 300 }}" alt="{{ item.product.title | escape }}" loading="lazy">
                </a>
              </div>
              
              <div class="cart-item-details">
                <h3><a href="{{ item.url }}">{{ item.product.title }}</a></h3>
                
                {%- if item.properties.size > 0 -%}
                  <div class="cart-item-properties">
                    {%- for property in item.properties -%}
                      <p><strong>{{ property.first }}:</strong> {{ property.last }}</p>
                    {%- endfor -%}
                  </div>
                {%- endif -%}
              </div>

              <div class="cart-item-price">
                {{ item.final_line_price | money }}
              </div>

              <div class="cart-item-remove">
                <a href="/cart/change?line={{ forloop.index }}&amp;quantity=0" aria-label="Remove {{ item.product.title | escape }} from cart">Remove</a>
              </div>
            </div>
          {% endfor %}
        </div>

        <div class="cart-summary">
          <div class="cart-notes">
            <label for="CartSpecialInstructions">Special Requests (Optional)</label>
            <textarea name="note" id="CartSpecialInstructions" placeholder="Tell us about special occasions or specific requests...">{{ cart.note }}</textarea>
          </div>

          <div class="cart-checkout-box">
            <div class="checkout-row">
              <span>Subtotal</span>
              <span>{{ cart.total_price | money }}</span>
            </div>
            <div class="checkout-row">
              <span>Taxes & Fees</span>
              <span>Calculated at checkout</span>
            </div>
            <div class="checkout-row checkout-total">
              <span>Estimated Total</span>
              <span>{{ cart.total_price | money }}</span>
            </div>
            
            <button type="submit" name="checkout" class="btn-checkout">Continue to Checkout</button>
            <p style="text-align: center; font-size: 11px; color: var(--text-muted); margin-top: 16px;">
              By proceeding, you agree to our booking terms and conditions.
            </p>
          </div>
        </div>
      </form>
    {% else %}
      <div class="cart-empty">
        <p>Your reservoir is currently empty. Our suites are waiting for you.</p>
        <a href="/collections/all" class="btn btn-primary">Discover Accommodations</a>
      </div>
    {% endif %}
  </div>
</div>

{% schema %}
{
  "name": "Cart Page",
  "settings": []
}
{% endschema %}
