<section class="hero">
  <div class="hero-image-wrapper">
    {% if section.settings.image %}
      <img src="{{ section.settings.image | img_url: 'master' }}" alt="{{ section.settings.heading }}" class="hero-image" loading="lazy">
    {% else %}
      {{ 'lifestyle-1' | placeholder_svg_tag: 'hero-image' }}
    {% endif %}
    <div class="hero-overlay"></div>
  </div>

  <div class="hero-content">
    {% if section.settings.tagline != blank %}
      <div class="hero-tagline">{{ section.settings.tagline }}</div>
    {% endif %}
    
    {% if section.settings.heading != blank %}
      <h1 class="hero-title">{{ section.settings.heading }}</h1>
    {% endif %}
    
    {% if section.settings.subheading != blank %}
      <p class="hero-subtitle">{{ section.settings.subheading }}</p>
    {% endif %}
  </div>

  <!-- Booking Bar Overlay -->
  <div class="booking-bar">
    <div class="booking-field">
      <label>Check In</label>
      <input type="date" id="hero-checkin" name="checkin">
    </div>
    <div class="booking-field">
      <label>Check Out</label>
      <input type="date" id="hero-checkout" name="checkout">
    </div>
    <div class="booking-field">
      <label>Guests</label>
      <select id="hero-guests">
        <option>1 Adult</option>
        <option selected>2 Adults</option>
        <option>2 Adults, 1 Child</option>
        <option>2 Adults, 2 Children</option>
      </select>
    </div>
    <a href="/collections/all" class="booking-btn" onclick="return passDatesToCatalog()">Check Availability</a>
  </div>
</section>

<script>
  // Simple script to pass selected dates to the catalog page via URL parameters
  function passDatesToCatalog() {
    const checkin = document.getElementById('hero-checkin').value;
    const checkout = document.getElementById('hero-checkout').value;
    
    if (checkin && checkout) {
      window.location.href = `/collections/all?checkin=${checkin}&checkout=${checkout}`;
      return false; // Prevent default link behavior
    }
    return true; // Let the link work normally if no dates selected
  }

  // Set minimum dates to today
  document.addEventListener('DOMContentLoaded', () => {
    const today = new Date().toISOString().split('T')[0];
    const checkin = document.getElementById('hero-checkin');
    const checkout = document.getElementById('hero-checkout');
    
    if (checkin) {
      checkin.min = today;
      checkin.addEventListener('change', (e) => {
        checkout.min = e.target.value;
        if (checkout.value && checkout.value < e.target.value) {
          checkout.value = e.target.value;
        }
      });
    }
    if (checkout) checkout.min = today;
  });
</script>

{% schema %}
{
  "name": "Luxury Hero Focus",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Background Image"
    },
    {
      "type": "text",
      "id": "tagline",
      "label": "Tagline",
      "default": "A Luxury Eco-Retreat Experience"
    },
    {
      "type": "html",
      "id": "heading",
      "label": "Heading",
      "info": "Use <em> tags for italicized keywords",
      "default": "Where Nature<br>Meets <em>Luxury</em>"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Nestled among pristine landscapes, Paradise Cove offers an intimate escape where natural beauty and refined comfort exist in perfect harmony."
    }
  ],
  "presets": [
    {
      "name": "Luxury Hero Focus"
    }
  ]
}
{% endschema %}
